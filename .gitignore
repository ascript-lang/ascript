# Rust build output
/target
# Compiled AScript bytecode artifacts
*.aso

# Parallel-development worktrees
/.worktrees

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
*.swp
*~

# Editor-extension build outputs (editors/* also carry their own .gitignore)
node_modules/
dist/
*.vsix
*.wasm
*.node
# …but the committed browser-playground artifact is the exception: the static docs site
# must run from a plain checkout (WASM §5.5), so the wasm-pack pkg/ for the playground is
# tracked. Build scratch (ascript-wasm/pkg, target/) stays ignored by the rules above.
!docs/assets/playground/pkg/
!docs/assets/playground/pkg/*.wasm

# Local tooling / session state — never publish
/.claude/
/.remember/
/goal.md

# Browser-automation (Playwright MCP) artifacts — verification screenshots, never publish
.playwright-mcp/
/page-*.png
/page-*.jpeg
/hero-*.png

# proptest failure-seed files. The campaign FIXES any differential failure in-branch
# with a real regression test (Gate 0), so these are transient debugging artifacts,
# not committed fixtures.
**/*.proptest-regressions
