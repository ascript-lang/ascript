{
  "name": "ascript",
  "displayName": "AScript",
  "description": "AScript language support: diagnostics, completion, hover, navigation, formatting, and semantic highlighting via the AScript language server.",
  "version": "0.6.0",
  "publisher": "ascript",
  "license": "MIT",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "ascript",
    "as",
    "language-server",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ascript-lang/ascript",
    "directory": "editors/vscode"
  },
  "icon": "icons/ascript.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:ascript",
    "workspaceContains:**/ascript.toml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ascript",
        "aliases": [
          "AScript",
          "ascript"
        ],
        "extensions": [
          ".as"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ascript.png",
          "dark": "./icons/ascript.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ascript",
        "scopeName": "source.ascript",
        "path": "./syntaxes/ascript.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AScript",
      "properties": {
        "ascript.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `ascript` binary. When empty, the extension discovers `ascript` on your `PATH`."
        },
        "ascript.server.autoDownload": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Download a per-platform prebuilt `ascript` server (checksum-verified) if none is found on `PATH` and no `ascript.server.path` is set."
        },
        "ascript.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the AScript language server."
        }
      }
    },
    "commands": [
      {
        "command": "ascript.restartServer",
        "title": "AScript: Restart Language Server"
      },
      {
        "command": "ascript.showServerVersion",
        "title": "AScript: Show Language Server Version"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.4.0"
  }
}
